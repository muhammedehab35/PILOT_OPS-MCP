# ─── Prometheus ──────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=

# ─── Grafana ─────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=                      # Grafana → Settings → API Keys → New key (role: Editor)
GRAFANA_ORG_ID=1

# ─── Loki ────────────────────────────────────────────────────
LOKI_URL=http://localhost:3100
LOKI_USERNAME=
LOKI_PASSWORD=

# ─── PagerDuty ───────────────────────────────────────────────
PAGERDUTY_API_KEY=                    # app.pagerduty.com → API Access Keys
PAGERDUTY_FROM_EMAIL=oncall@yourcompany.com
PAGERDUTY_SERVICE_ID=                 # app.pagerduty.com → Services → votre service → ID dans l URL
PAGERDUTY_ESCALATION_POLICY_ID=       # app.pagerduty.com → Escalation Policies → ID dans l URL

# ─── Slack ───────────────────────────────────────────────────
SLACK_BOT_TOKEN=                      # api.slack.com → Your Apps → OAuth Tokens
SLACK_DEFAULT_CHANNEL=#incidents
